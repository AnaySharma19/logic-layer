# ─────────────────────────────────────────────────────────────
# Logic Layer — .env.example
#
# Copy this file to `.env` and fill in real values for local dev.
# NEVER commit a real `.env` — `.gitignore` already excludes it.
#
# Variable naming convention: <SECTION>_<PURPOSE>
# ─────────────────────────────────────────────────────────────

# ── General ──
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=replace-me-with-a-long-random-string

# ── Database (PostgreSQL — verdict history, metadata, logs) ──
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=logic_layer
DATABASE_USER=logic_layer
DATABASE_PASSWORD=change-me

# ── Middleware / FastAPI ──
MIDDLEWARE_HOST=0.0.0.0
MIDDLEWARE_PORT=8000
MIDDLEWARE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Target AI agents (the agents Logic Layer wraps) ──
# Add a block per agent. The middleware reads these to build connectors.
AGENT_DEFAULT_API_KEY=sk-replace-me
AGENT_DEFAULT_BASE_URL=https://api.example.com/v1
AGENT_DEFAULT_MODEL=gpt-4o-mini

# ── Claim extraction ──
# Used by the response-to-atomic-claims decomposer (LLM function-calling).
CLAIM_EXTRACTION_API_KEY=sk-replace-me
CLAIM_EXTRACTION_MODEL=gpt-4o-mini

# ── Contradiction detector (Layer 3 of the verification pipeline) ──
# If hosting a local NLI model, point to the weights path; otherwise an API.
CONTRADICTION_MODEL_BACKEND=local                   # local | api
CONTRADICTION_MODEL_PATH=./models/nli-model
CONTRADICTION_API_KEY=
CONTRADICTION_API_URL=

# ── Local knowledge base (Layer 1) ──
LKB_FACTS_DIR=./local-knowledge-base/facts
LKB_SOURCES_DIR=./local-knowledge-base/sources
LKB_EMBEDDINGS_DIR=./local-knowledge-base/embeddings
LKB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LKB_VECTOR_STORE_BACKEND=chroma                    # chroma | faiss

# ── Trusted source check (Layer 2) ──
TRUSTED_SOURCES_CONFIG=./middleware/config/trusted_sources.yml
GOV_FALLBACK_ENABLED=true
SEARCH_RATE_LIMIT_PER_MINUTE=30

# ── Feedback loop (correction pass back to the AI agent) ──
FEEDBACK_LOOP_MAX_RETRIES=2                        # see PLAN.md §6 — retry-limit open risk

# ── UI client ──
UI_DASHBOARD_PORT=3000
UI_BROWSER_EXTENSION_ID=

# ── Scheduler / refresh jobs (Phase 7) ──
KB_REFRESH_CRON=0 3 * * *                          # nightly at 03:00 local
SOURCE_RECHECK_CRON=0 4 * * 0                      # weekly Sunday 04:00 local

# ── Observability ──
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=